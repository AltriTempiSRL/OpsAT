# ── Credenciales Odoo ERP ─────────────────────────────────────────────────────
# Obtener desde: Odoo → Ajustes → Técnico → Usuarios → API Keys
ODOO_URL=https://tu-empresa.odoo.com
ODOO_DB=nombre-de-tu-base-de-datos
ODOO_USER=tu-email@empresa.com
ODOO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Nombre de la empresa (aparece en la interfaz) ─────────────────────────────
COMPANY_NAME=Tu Empresa

# ── Google Sheets — Control de Contenedores (opcional) ───────────────────────
# ID del spreadsheet (visible en la URL de Google Sheets)
CONT_SHEETS_ID=
CONT_SHEETS_GID=0

# ── Seguridad JWT ────────────────────────────────────────────────────────────
# Genera uno seguro en: https://generate-secret.vercel.app/64
# OBLIGATORIO en producción
JWT_SECRET=genera-un-string-aleatorio-de-64-caracteres-aqui

# ── Directorio de datos persistentes ─────────────────────────────────────────
# En Render.com: /data  (disco persistente montado)
# En desarrollo local: dejar vacío (usa el directorio del proyecto)
DATA_DIR=

# ── Puerto del servidor ───────────────────────────────────────────────────────
# Render lo asigna automáticamente; no cambiar en producción
PORT=3000

# ── IA de agentes ────────────────────────────────────────────────────────────
# Toda la IA (Gerente de Operaciones + Auditor de Procesos) corre con OpenAI.
OPENAI_API_KEY=
CODEX_AUDITOR_MODEL=gpt-5.5
# (El SDK de Anthropic se removió — anthropicClient nunca se invocaba. Para volver
#  a Claude: reinstalar @anthropic-ai/sdk, cablear anthropicClient y setear la key.)
# ANTHROPIC_API_KEY=

# ── Codex Bridge ─────────────────────────────────────────────────────────────
# Token privado para que Codex/ChatGPT pueda consultar datos vivos de Workforce
# sin usar la API de OpenAI dentro de Railway. Usar un string largo y aleatorio.
CODEX_BRIDGE_TOKEN=
